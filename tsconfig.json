{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "types": [
            "vitest/globals"
        ]
    },
    "include": [
        "tests/**/*"
    ],
    "exclude": [
        "node_modules",
        "frontend"
    ]
}